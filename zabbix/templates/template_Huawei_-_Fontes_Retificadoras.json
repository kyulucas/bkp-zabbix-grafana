              {
                "uuid": "81c14e90a1d246d985c05a90622dcfd2",
                "expression": "last(/Huawei - Fontes Retificadoras/acInputOperStatus)=2 or last(/Huawei - Fontes Retificadoras/acInputOperStatus)=3",
