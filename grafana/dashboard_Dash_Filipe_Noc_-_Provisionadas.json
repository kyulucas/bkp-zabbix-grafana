          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    TIMESTAMP(o.DATA_OPERACAO, o.HORA_OPERACAO) AS time,\r\n    o.LOGIN,\r\n    CONCAT(o.SLOT,'/',o.PORTA) AS PON,\r\n    olt.NOME AS OLT,\r\n    cto.NOME AS CTO\r\nFROM FTTH_ONUS o\r\nLEFT JOIN FTTH_OLTS olt\r\n    ON olt.COD_OLT = o.COD_OLT\r\nLEFT JOIN FTTH_CTO cto\r\n    ON cto.COD_CTO = o.COD_CTO\r\nWHERE TIMESTAMP(o.DATA_OPERACAO, o.HORA_OPERACAO)\r\nBETWEEN FROM_UNIXTIME($__unixEpochFrom())\r\nAND FROM_UNIXTIME($__unixEpochTo())\r\nORDER BY time;",
