          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    olt.NOME        AS OLT,\r\n    pon.NOME        AS PON,\r\n    COUNT(onu.ID)   AS QTD_ONTS\r\nFROM FTTH_OLTS olt\r\nINNER JOIN FTTH_OLT_PORTS pon\r\n    ON pon.COD_OLT = olt.COD_OLT\r\nLEFT JOIN FTTH_ONUS onu\r\n    ON onu.COD_OLT_PORTA = pon.COD_OLT_PORTA\r\n   AND onu.COD_OLT = olt.COD_OLT\r\nWHERE olt.EXCLUIDO = 'N'\r\n  AND pon.EXCLUIDO = 'N'\r\nGROUP BY\r\n    olt.NOME,\r\n    pon.NOME\r\nORDER BY\r\n    QTD_ONTS DESC;",
